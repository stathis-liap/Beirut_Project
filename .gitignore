# ============================================================
# Beirut_Project — ignore large / reproducible binaries.
# The point clouds, raster arrays, run outputs and videos are
# reproducible from the scripts + the source LiDAR survey and
# are far too large for GitHub, so only code, docs, reports and
# small result artifacts are tracked.
# ============================================================

# Point clouds and archives
data/
*.las
*.laz
*.zip

# Videos
*.mp4

# Raster arrays and grids (regenerated by the pipeline)
*.npy
*.npz
*.asc
*.tif
*.tiff

# Very large loose preview rasters
output/preview_*.png

# Logs and LaTeX / Python build artifacts
*.log
texput.log
*.aux
*.out
*.toc
__pycache__/
*.pyc
.venv/
.venv_synxflow/
