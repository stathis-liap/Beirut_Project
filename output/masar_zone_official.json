{"objectIdFieldName":"OBJECTID","uniqueIdField":{"name":"OBJECTID","isSystemMaintained":true},"globalIdFieldName":"GlobalID","geometryProperties":{"shapeAreaFieldName":"Shape__Area","shapeLengthFieldName":"Shape__Length","units":"esriMeters"},"geometryType":"esriGeometryPolygon","spatialReference":{"wkid":32636,"latestWkid":32636},"fields":[{"name":"Id","type":"esriFieldTypeInteger","alias":"Id","sqlType":"sqlTypeOther","domain":null,"defaultValue":null},{"name":"OBJECTID","type":"esriFieldTypeOID","alias":"OBJECTID","sqlType":"sqlTypeOther","domain":null,"defaultValue":null},{"name":"GlobalID","type":"esriFieldTypeGlobalID","alias":"GlobalID","sqlType":"sqlTypeOther","length":38,"domain":null,"defaultValue":null},{"name":"Shape__Area","type":"esriFieldTypeDouble","alias":"Shape__Area","sqlType":"sqlTypeDouble","domain":null,"defaultValue":null},{"name":"Shape__Length","type":"esriFieldTypeDouble","alias":"Shape__Length","sqlType":"sqlTypeDouble","domain":null,"defaultValue":null},{"name":"Project_Des","type":"esriFieldTypeString","alias":"Project_Des","sqlType":"sqlTypeOther","length":2000,"domain":null,"defaultValue":null}],"features":[{"attributes":{"Id":0,"OBJECTID":1,"GlobalID":"97a8ef5d-5c9c-4f72-abee-cde1e658a0ed","Shape__Area":190276.02172851563,"Shape__Length":2687.0777437100078,"Project_Des":"The Green Path project – Al-Masar Al-Akhdar – is a public space initiative conceived as an alternative to the Fouad Boutros Highway that had been planned in the 1950s – as part of the approved Ecochard Master Plan – to form a North-South connection between the Charles Helou and Charles Malek highways, cutting through Mar Mikhael up to the Hikmeh hill. It is the work of a collective imaginary advocating for a new vision of the city that offers city-dwellers better public space and residential infrastructures. These translate into enhanced pedestrian and soft mobilities, desirable recreational spaces, and an expansion and upgrading of the housing stock, ultimately materializing into a real improvement of the urban quality of life. The project is the fruit of years of civil mobilization that have challenged the implementation of the Fouad Boutros highway.  As several lands and buildings were expropriated in the seventies, the cancellation of the road project brings an opportunity to re-envision this trajectory as a green corridor of public spaces. This initiative, which is championed by a handful of Beirut-based actors , promotes an innovative approach to reclaim the green and open public spaces in the Green Path, and to co-produce an integrated approach that brings together public, private, and non-profit actors where academic research centers can support collaborative visioning."},"geometry":{"rings":[[[733301.8765875,3753751.93088311],[733311.0835875,3753730.30978311],[733343.5823875,3753607.99248311],[733389.7090875,3753518.30088311],[733343.9858875,3753486.24178311],[733350.7219875,3753445.22658311],[733343.4711875,3753440.92458311],[733351.5082875,3753427.55618311],[733336.3158875,3753418.29458311],[733355.2358875,3753400.94858311],[733320.4123875,3753347.30598311],[733316.1668875,3753346.65068311],[733265.0020875,3753338.00818311],[733255.3814875,3753336.16528311],[733244.6845875,3753275.57368311],[733251.7079875,3753252.46528311],[733254.4431875,3753168.61848311],[733280.6570875,3753164.43288311],[733250.4373875,3753050.68248311],[733195.9379875,3753036.32398311],[733194.5921875,3753018.01998311],[733192.6326875,3752974.55608311],[733187.5396875,3752967.98448311],[733182.6044875,3752967.26628311],[733183.1557875,3752955.50928311],[733186.5639875,3752955.21078311],[733189.1172875,3752910.92378311],[733145.7859875,3752907.54008311],[733145.5297875,3752910.85588311],[733141.8242875,3752910.58358311],[733141.0035875,3752916.27898311],[733130.6078875,3752915.14528311],[733134.9176875,3752864.19888311],[733068.3857875,3752865.25088311],[733051.1132875,3752859.84838311],[733053.3650875,3752884.29578311],[733053.5747875,3752894.153